PORT=3001
NODE_ENV=development
DEVELOPMENT=true
PRODUCTION=false
JWT_SECRET=change-this
FRONTEND_URL=http://localhost:8080

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Postgres via Supabase (required in production; ignored in development)
# Set USE_SUPABASE=true to use Postgres locally instead of LowDB
USE_SUPABASE=false
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.PROJECT.supabase.co:5432/postgres
AIVEN_DATABASE_URL=postgresql://avnadmin:[YOUR-PASSWORD]@pg-xxxx.aivencloud.com:27240/defaultdb?sslmode=require
AIVEN_CA_CERT_PATH=./certs/aiven-ca.pem
# Optional alternative to path:
# AIVEN_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Password reset TTL/cooldown are hardcoded in src/config/env.ts (120 min / 5 min).
